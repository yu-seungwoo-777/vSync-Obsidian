{
  "name": "vector",
  "version": "0.1.0",
  "description": "Self-hosted knowledge management platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "kill-ports": "fuser -k 3000/tcp 5173/tcp 2>/dev/null; true",
    "dev": "npm run kill-ports && concurrently -n server,web -c blue,green \"npm run dev -w packages/server\" \"npm run dev -w packages/web\"",
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "build": "npm run build -ws",
    "test": "npm run test -ws",
    "test:coverage": "npm run test:coverage -ws",
    "lint": "npm run lint -ws",
    "generate-types": "npm run generate-types -w packages/server && npm run generate-types -w packages/plugin",
    "typecheck": "npm run typecheck -ws"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
