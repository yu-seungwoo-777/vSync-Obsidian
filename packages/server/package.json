{
  "name": "@vector/server",
  "version": "0.1.0",
  "description": "Vector sync server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "sync:git": "tsx src/cli/git-sync.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:check": "eslint src/ --max-warnings 20",
    "typecheck": "tsc --noEmit",
    "generate-types": "openapi-typescript ../../docs/api/openapi.yaml -o src/types/api-types.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.780.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.0.0",
    "@types/diff-match-patch": "^1.0.36",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^5.1.1",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.42.0",
    "fastify": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.25.0",
    "eslint-plugin-check-file": "^3.3.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.1.0",
    "ws": "^8.20.0"
  }
}
